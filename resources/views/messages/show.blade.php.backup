@section('js')
<script>
	$(function() {
		'use strict';

		let isSubmitting = false;

		// Auto-scroll to bottom on load
		function scrollToBottom() {
			const chatBody = document.getElementById('ChatBody');
			if (chatBody) {
				chatBody.scrollTop = chatBody.scrollHeight;
			}
		}

		// Mark conversation as having new message (don't reload page to avoid duplicates)
		function updateConversationsList() {
			// Page reload removed to prevent duplicate message display
			// The conversation is created/updated automatically in the backend
		}

		scrollToBottom();

		// Handle form submission with AJAX
		$('#messageForm').on('submit', function(e) {
			e.preventDefault();

			// Prevent double submission
			if (isSubmitting) {
				return;
			}

			const content = $('#messageInput').val().trim();

			if (!content) return;

			isSubmitting = true;
			const $button = $(this).find('button[type="submit"]');
			$button.prop('disabled', true);

			$.ajax({
				url: $(this).attr('action'),
				method: 'POST',
				data: {
					_token: $('[name="_token"]').val(),
					receiver_id: $('[name="receiver_id"]').val(),
					content: content
				},
				dataType: 'json',
				success: function(response) {
					if (response.success) {
						const message = response.message;
						const avatar = message.sender.profile && message.sender.profile.avatar
							? message.sender.profile.avatar
							: '/assets/img/faces/6.jpg';

						const messageHtml = `
							<div class="message-group sent">
								<div class="text-right">
									<div class="message-bubble sent">
										${message.content}
									</div>
									<div class="message-time">
										Just now
										<span class="message-status unread">
											<i class="fas fa-check checkmark"></i> Sent
										</span>
									</div>
								</div>
							</div>
						`;

						$('#ChatBody').append(messageHtml);
						$('#messageInput').val('').focus();
						scrollToBottom();

						// Update conversations list (no page reload to prevent duplicates)
						updateConversationsList();
					}
				},
				error: function(xhr) {
					alert('Error sending message. Please try again.');
				},
				complete: function() {
					isSubmitting = false;
					$button.prop('disabled', false);
				}
			});
		});

		// Focus input on load
		$('#messageInput').focus();
	});
</script>
<script src="{{ asset('js/messages-realtime.js') }}"></script>
@endsection
